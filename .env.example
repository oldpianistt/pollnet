# Copy to .env and fill in real values before `docker compose -f docker-compose.prod.yml up`.
# .env is gitignored.

# Postgres credentials (used by both the postgres container and the backend).
POSTGRES_DB=pollnet
POSTGRES_USER=pollnet
POSTGRES_PASSWORD=change-me

# Must be at least 32 bytes. Generate one with: openssl rand -base64 48
POLLNET_JWT_SECRET=please-replace-this-with-at-least-32-bytes-of-random-secret

# Optional overrides
# POLLNET_JWT_ACCESS_TTL_MINUTES=15
# POLLNET_JWT_REFRESH_TTL_DAYS=30
# WEB_PORT=80

# Spring profile — set to "prod" in production for JSON logs.
# SPRING_PROFILES_ACTIVE=prod

# Mail (when MAIL_ENABLED=false the service logs messages instead of sending).
# MAIL_ENABLED=false
# MAIL_FROM=no-reply@your-domain
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_AUTH=true
# SMTP_STARTTLS=true

# Public base URL used in verification / password-reset email bodies.
# PUBLIC_BASE_URL=https://your-domain

# Allowed origin patterns for CORS (comma-separated). When the SPA is served
# from the same origin as the API (production with nginx reverse-proxy), CORS
# is unused. Set this only if you serve the FE from a different domain.
# POLLNET_CORS_ORIGINS=https://app.your-domain,https://staging.your-domain

# Domain used by the certbot sidecar in docker-compose.tls.yml.
# DOMAIN=your-domain

# Sentry — set DSN to enable error reporting. Empty/unset → SDK is no-op.
# Backend (read at runtime):
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=prod
# SENTRY_RELEASE=0.1.0
# SENTRY_TRACES_SAMPLE_RATE=0.05
# Frontend (baked into the bundle at build time):
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=prod
# VITE_SENTRY_RELEASE=0.1.0
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
# VITE_SENTRY_REPLAYS_SAMPLE_RATE=0.0
